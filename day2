        // 어떤 값을 올리거나 내리는 연산자
        // ++, --
        int count = 0;
        // count += 1;
        // 위 아래 코드 같은 역할임
        // 후증감연산자는 연산기호가 뒤에 옴 count++; count--; 
      
        //++count; 선증감연산자는 연산기호가 앞에 옴
        //--count;
        // 단독으로 사용할 때, 동작 자체는 선증감, 후증감 모두 동일하나
        // 선증감 연산자가 어셈블리(low lv)언어이기 때문에 선증감 연산자가 유리함(권장)
        Debug.Log(count);

        // 비교연산자
        // <, >, >=, <=, ==, !=
        // 2 > 1 -> 크다 (맞다)
        // 1 > 2 -> 틀렸다
        // 2 > 0 -> 맞다
        // 3 > 100 -> 틀렸다
        // 비교연산을 하게 되면 참/거짓의 형태가 나옴
        // C#에서는 bool 형 변수

        bool bb = 2 > 1;
        Debug.Log(bb);

        // ==, !=
        // 같다 라는 뜻 , 같지 않다 라는 뜻
        // MultiLine Select
        // alt + Shift + 방향키
        bool b1 = 1 == 1; //True
        bool b2 = 2 == 1; //False
        bool b3 = 1 != 1; //False
        bool b4 = 2 != 1; //True
        Debug.Log(b1);
        Debug.Log(b2);
        Debug.Log(b3);
        Debug.Log(b4);

        // 논리연산자
