        // 내가 이 아이템을 살 수 있는 레벨인가?
        // 내가 이 아이템을 살 수 있는 돈이 있는가?
       
        int level = 10;
        int money = 100;

        // 1. 착용 레벨을 만족하고, 돈도 있어야 살 수 있는 경우
