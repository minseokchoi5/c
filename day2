        // &&를 사용함
        // 착용 레벨 : 5 이상, 필요한 돈  : 50원
        bool bb1 = (level >= 5) && (money >= 50);
        Debug.Log(bb1);

        // 2. 착용 레벨을 만족하거나, 돈이 있을 때에 아이템을 살 수 있는 경우
