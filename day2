        int itemPrice = 2000;
        //  - 나의 소지금액 (정수형)
        int wallet = 10000;
        // 2. 아이템을 구매하는 로직 (-)
        //wallet - itemPrice; //8000
        // 3. 뺀 결과를 지갑에 반영해줘야 함
        wallet = wallet - itemPrice;
        // 복합대입연산자 -= 는
        // 위 코드를 축약해서 나타냄
        // 위 코드와 같은 동작을 함
        wallet -= itemPrice;
        Debug.Log(wallet);
        // *=, +=, /=, %= ex(wallet = wallet % itemPrice;)

        // 증감연산자
        // 1. 선증감 연산자
