        int a = 1;
        int b = 2;

        // 저장된 1과 2를 가져와서 더하기
        // -> 공간의 별칭(변수명) 을 사용해서 가져오면 됨
        //a + b; // ctrl + k + c 선택영역 주석 처리 단축키

        // 더한 값을 새로운 저장공간에 넣으면 되겠네
        // -> 변수를 만들고 더한 값을 저장하면 되겠네
        int c = a + b;
        Debug.Log(c);

        Debug.Log(1 + 2); //3
        Debug.Log(1 - 2); //-1
        Debug.Log(100 * 2); // 200
        Debug.Log(1f / 2f); // 0.5

        // % - 나머지 연산자 (보통 홀수, 짝수 확인으로 많이 사용)
        // 일단은 나누기랑 똑같은데, 나누고 나서, 몫이랑 나머지가 생성되는데,
        // 거기서 나머지만 읽어오는 연산자임
        // 5 / 2 = 2... 1
        // 5 % 2 = 1
        Debug.Log(5 % 2); //1
        Debug.Log(6 % 2); //0
        Debug.Log(7 % 2); //1
        Debug.Log(8 % 2); //0

        // 실수형 자료형, 정수형 자료형을 빼기
        // 묵시적 형변환이 일어나서
        // 실수 - 정수를 하면 실수형 결과가 나옴
        // 다른 형태의 자료형을 뺄때는, 더 정밀한 쪽의 자료형으로 변환하여 계산함 (데이터 유실 방지)
        float f = 3.14f;
        int i = 1;
        Debug.Log(f - i);

        // 문자열 + 숫자
        // string + int
        // Hello + 123
        Debug.Log("Hello" + 123);
        int age = 10;
        Debug.Log(age);
        Debug.Log("제 나이는 : " + age + "살 입니다.");

        // 대입연산자
        // =, +=, -=, *=, %=
        int aa = 10;

        // 지갑에 10000원이 있음
        // 아이템을 하나 살거임
