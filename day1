// 주석 (commendts)
// 주석은 프로그램 컴퓨터가 이해할 수 있는 코드 파일에
// 사람이 이해하기 좋은 자연어를 적을 수 있도록
// 해주는 기능임
// 프로그램 언어를 0과 1로 이루어진 코드로
// 변환할때, 대상에서 제외가 됨
// 언어마다 주석을 다는 방법이 다름
// C#은 '//'를 사용하여 표기함


// Visual Studio
// IDE(Integrated Development Environment) 통합 개발 환경
// 코드를 작성하기 쉽게, 돌리기 쉽게, 버그를 찾기 쉽게
// 만들어주는 프로그램

// Visual Studio Code (고급 사용자 프로그램)

// 컴퓨터는 0과 1밖에 모름
// 우리가 작성한 코드를 0과 1로 변환을 시켜줘야 함
// 그 과정을 컴파일(Compile)이라고 함
// 컴파일러(Compiler) : 컴파일을 해주는 프로그램

// 자료형 - Data Type
// 자료의 형태를 정해주는 녀석
// 1,2,3,4 / a,b,c,d / 3.14 20.91 을 표현해줘야하는데,
// 0과 1밖에 모르는 컴퓨터에서
// 데이터를 읽는 방식을 정의함
// 0과 1을 이해하는 방식을 자료형이라고 함

// 데이터를 저장하고, 읽어올 때 자료형이 필요함
// 그렇다면 필히 데이터를 저장하는 방식도 필요함
// 데이터를 저장하는 방식을 변수(Variable)라고 함
// 변수
// 메모리에 공간을 만들고, 거기에 값을 바꿔가며 저장을 하자
// 라는 취지에서 나옴

// 메모리에 데이터를 저장하고, 불러올때는 필히 다음과 같은 요소들이 필요함
// 1. 어떤 형식으로 자료를 저장할지(자료형)
// 2. 메모리 공간에 저장된 자료를 불러올 때, 어떤 이름으로 불러올지 별칭(변수명)
// 3. 어떤 값을 저장할지(값)

// 정수형(1,2,3,4)
// 실수형(3.14, 20.91)
// 문자형('a','b','c','d')
// 문자열("안녕하세요", "반갑습니다", "Hello", "Hi")
// 논리형(true, false)

// 누가 만들어 놓은 어떤 기능을 쓸 때 (using 계산기 등)
using UnityEngine;

// class 같은 기능을 하는 정보들의 집합체
// MonoBehaviour : 유니티에서 제공하는 클래스 (유니티에서 엔진을 돌리기 위해 만들어 놓은 확장 기능)
public class DataType : MonoBehaviour
{
    // 게임이 시작될 때, 최초 1번만 실행되는 함수가 있음
    // Start() : 게임이 시작될 때, 최초 1번만 실행되는 함수

    private void Start()
    {
        Debug.Log("발동!");

        // 1,2,3,4 와 같은 정수형 데이터를 저장하고, 출력 해보고 싶음
        // 정수는 integer의 약자로 int라고 표기함
        // 그 공간 이름을 a라고 부름
        // 3을 저장하고 싶음
        int a = 3;
        // 같은 별칭(변수명)으로는 공간을 만들 수 없음
        // 불러올 때, 헷갈리기 때문임
        // int a = 4;
        Debug.Log(a);
        a = 4;
        Debug.Log(a);

        // 변수를 만들 때, 공간의 제약 없이 메모리를 차지해 버리면
        // 효율이 너무 안좋음
        // 따라서, 자료형 마다 정해진 크기가 있음
        // 4byte
        int intSize = sizeof(int);
        Debug.Log(intSize);
        //int형의 크기는 4 Byte
        // 1byte = 8bit

        // 메모리에 어떤 자료형의 변수를 저장할 때, 언어가 정해둔 크기만큼을 할당 받게 됨
        // int는 4byte를 할당 받음
        // 메모리에 0과 1이 저장될 수 있는 한칸을 bit라고 함
        // 그 bit가 8개 모이면 byte라고 함
        // int는 4byte 즉, 32bit를 할당 받음
        // 즉 2^32개의 (약 42억) 데이터를 저장할 수 있음
        // 정수는 음수도 존재하기 때문에 맨 앞의 비트를 부호비트로 지정함
        // 따라서 숫자를 표현할 수 있는 칸은 31비트이기 때문에
        // -21억 4748만 3648 ~ 21억 4748만 3647 까지의 범위를 표현할 수 있음

        // 만약, 32비트 짜리 int의 최댓값에 1을 더해서 33비트가 되면 어떻게 되는가?
        // 비트가 앞으로 한칸씩 미려서 의도한 숫자가 나오지 않음
        // 이 현상을 overflow락고 함

        // 실수형 자료형
        // 실수형을 표현할 때는 2가지 방식이 있음
        // 1. 고정 소수점 방식
        // 소수점을 정해두고 소수를 표현하는 방식
        // 표현은 쉽지만 메모리 효율이 안나옴
        // 2. 부동 소수점 방식
        // 소수점을 고정하지 않고, 소수점이 움직이면서 표현하는 방식
        // 메모리 효율은 좋지만, 표현이 어렵고, 오차가 발생함 (계산이 느리고 복잡)

        // 부동소수점 방식을 많이 씀
        // floating point의 약자로 float라고 표기함 (실수를 다루는 자료형)
        // 자료 뒤에 f를 붙여야 float형으로 인식함 ex) 3.14f, 20.91f


        // 실수를 저장하고 출력 하고 싶음
        // 어떤 자료형인지, 공간이름을 뭐라고 부를지, 어떤 값을 넣을지
        float f = 3.14f;
        Debug.Log(f);

        // float이라는 자료형이 메모리에서 얼마만큼의 공간을 차지하는지 알고 싶음
        int floatSize = sizeof(float);
        Debug.Log(floatSize);

        // double 자료형
        // float 보다 더 정밀한 실수를 표현할 수 있는 자료형
        double d = 3.14;
        Debug.Log(d);
        int doublesize = sizeof(double);
        Debug.Log(doublesize);

        // 문자형
        // a,b,,c,ㄱ,ㄴ,ㄷ
        // 0과 1밖에 모르는 컴퓨터에서 문자를 표현하기 위해서는
        // 문자를 숫자로 변환해서 저장해야 함
        // 문자를 숫자로 변환하는 방식을 인코딩(Encoding)이라고 함
        // 문자를 숫자로 변환하는 방식은 여러가지가 있음
        // 유니티에서는 UTF-16이라는 방식을 사용함
        // UTF-16은 2byte를 사용함
        // 숫자와 알파벳을 연결하여 약속하는 방식을 고안하게 되었음
        // 결국 저장된 것은 숫자이기 때문에, 문자를 저장하는 자료형을 알려주면
        // 숫자를 문자로 읽도록 설정함
        // 문자와 숫자를 연결한 표를 아스키코드(ASCII Code)라고 함

        // 문자는 character라고 부르고, 약자로 char라고 표기함
        // 표기는 ' '로 표기함
        char c = 'a';
        Debug.Log(c);

        // 형 변환
        // 변수 앞에 바꾸고 싶은 자료형을 넣으면 됨
        // 명시적 형 변환 (Explicit Conversion)
        Debug.Log((int)c);

        // 묵시적 형 변환 (Implicit Conversion)
        // 개발자가 따로 형변환을 하라고 명령하지 않아도
        // 컴파일러가 알아서 형변환을 해주는 것
        int ic = 'b';
        Debug.Log((char)ic);

        int charSize = sizeof(char);
        Debug.Log(charSize);

        // 문자열 형
        // 안녕하세요, hello, abcde 문자들이 모인 형태를 나타내고 싶음

        // 문자 한개는 영어 기준 크게 경우의 수가 많이 없음
        // 100~200개의 경우의 수에서 해결이 됨
        // "abcd", "dacb" 와 같이 문자열은 경우의 수가 너무 많기 때문에
        // 문자처럼 숫자와 문자를 1대 1 대응 시키는 것은 사실상 불가능함
        // 문자 한개가 2바이트 고정이니까 문자열을 읽을 때,
        // 첫번째 문자의 위치만 기억을 하고, 2바이트씩 띄워서 읽자
        // 문자열을 저장할 때는 문자열에 " " 를 붙여서 저장함
        // 문자열은 string 이라고 표기함

        string str = "안녕하세요";
        Debug.Log(str);
        // string의 크기는 char의 크기 * 문자의 갯수

        // 참 거짓 형
        // 참인지 거짓인지 판명하고 싶음
        // boolean 대수를 바탕으로 만들어짐
        // 앞글자만 떼서 bool 형 이라고 함
        bool b1 = true;
        bool b2 = false;
        int boolSize = sizeof(bool);
        Debug.Log(b1); // 줄복사 단축키 ctrl + D
        Debug.Log(b2);
        Debug.Log(boolSize);
      }
}
